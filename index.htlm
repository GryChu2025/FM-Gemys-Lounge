<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>FM Gemys Lounge</title>

<style>
body{
    background:#000;
    color:#fff;
    font-family:Arial,sans-serif;
    text-align:center;
    margin:0;
    padding:20px;
}

.logo{
    width:300px;
    max-width:90%;
    margin-bottom:20px;
}

.slogan{
    font-size:20px;
    margin-bottom:25px;
}

.btn{
    display:block;
    width:280px;
    margin:10px auto;
    padding:15px;
    border:2px solid #d4af37;
    border-radius:15px;
    color:white;
    font-size:18px;
}

.player-btn{
    background:#d4af37;
    color:black;
    border:none;
    border-radius:10px;
    padding:15px 30px;
    margin:10px;
    font-size:18px;
    cursor:pointer;
    font-weight:bold;
}
</style>

</head>

<body>

<img src="logo.png" class="logo" alt="FM Gemys Lounge">

<div class="slogan">
Música inteligente para cada negocio
</div>

<div class="btn">🍽️ Restaurantes</div>
<div class="btn">🛒 Supermercados</div>
<div class="btn">👗 Tiendas</div>
<div class="btn">🏨 Hoteles</div>
<div class="btn">🚗 Viajeros</div>
<div class="btn">🌙 Lounge</div>

<audio id="radio">
<source src="http://45.182.223.219:8000/stream" type="audio/mpeg">
</audio>

<button class="player-btn" onclick="document.getElementById('radio').play()">
▶ PLAY
</button>

<button class="player-btn" onclick="document.getElementById('radio').pause()">
⏸ PAUSA
</button>

</body>
</html>
